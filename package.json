{
  "name": "english-path-ai",
  "version": "0.1.0",
  "description": "AI-powered Telegram tutor that takes learners from A2 to C1, with dedicated IELTS & Digital SAT prep.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "bot:webhook:set": "tsx scripts/set-webhook.ts",
    "bot:webhook:delete": "tsx scripts/delete-webhook.ts"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@hono/node-server": "^1.13.7",
    "@prisma/client": "^6.3.1",
    "dotenv": "^17.4.2",
    "grammy": "^1.31.0",
    "hono": "^4.6.16",
    "node-cron": "^4.6.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^4.1.10"
  }
}
