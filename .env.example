# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
# development | production

# ── Telegram ─────────────────────────────────────────────────────────
# Get this from @BotFather (/newbot). Never commit the real value.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs that get admin-panel access.
# Find your own ID by messaging @userinfobot.
ADMIN_TELEGRAM_IDS=

# Webhook mode (used in production, e.g. on Render).
# Leave both empty to fall back to long-polling (used in local dev).
BOT_WEBHOOK_URL=
# e.g. https://english-path-ai.onrender.com
BOT_WEBHOOK_SECRET=
# random string, e.g. `openssl rand -hex 32`

# HTTP server (webhook receiver + /health endpoint for UptimeRobot)
PORT=3000

# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL connection string (Render Postgres, Supabase, Neon, or local).
DATABASE_URL=postgresql://user:password@localhost:5432/english_path_ai

# ── AI provider ──────────────────────────────────────────────────────
# gemini | openai | anthropic | none
AI_PROVIDER=gemini

# Free tier key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional providers if you swap AI_PROVIDER
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ── Misc ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
# trace | debug | info | warn | error
DEFAULT_TIMEZONE=Europe/Kyiv
